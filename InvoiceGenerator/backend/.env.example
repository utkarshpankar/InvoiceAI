# Render / production backend environment variables

NODE_ENV=production
PORT=4000

# MongoDB Atlas connection string (variable name must be MONGO_URI)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/invoicegenerator?retryWrites=true&w=majority

# Clerk production keys (Dashboard → API Keys → Production)
CLERK_SECRET_KEY=your_clerk_secret_key_here
CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here

# Public backend URL (used for uploaded file URLs)
BACKEND_URL=https://invoiceai-d983.onrender.com

# Deployed Vercel frontend URL (comma-separated for multiple origins)
FRONTEND_URL=https://invoice-ai-five-sepia.vercel.app

# Optional: additional allowed origins (comma-separated)
# ALLOWED_ORIGINS=https://www.your-domain.com

# Optional: allow Vercel preview deployments (*.vercel.app)
# ALLOW_VERCEL_PREVIEWS=true

# Gemini API key (optional, for AI invoice generation)
GEMINI_API_KEY=your_gemini_api_key

# Vercel / production frontend environment variables
# Set these in Vercel → Project → Settings → Environment Variables
# Values are baked in at build time — redeploy after changing them.

# Render backend URL (no trailing slash)
VITE_API_BASE_URL=https://invoiceai-d983.onrender.com

# Clerk production publishable key (pk_live_... — NOT pk_test_)
VITE_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
